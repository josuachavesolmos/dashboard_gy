{
  "id": "${{AAD_APP_OBJECT_ID}}",
  "appId": "${{AAD_APP_CLIENT_ID}}",
  "name": "Axess-Dashboard-${{TEAMSFX_ENV}}",
  "accessTokenAcceptedVersion": 2,
  "signInAudience": "AzureADMyOrg",
  "optionalClaims": {
    "idToken": [],
    "accessToken": [
      {
        "name": "idtyp",
        "source": null,
        "essential": false,
        "additionalProperties": []
      }
    ],
    "saml2Token": []
  },
  "requiredResourceAccess": [
    {
      "resourceAppId": "Microsoft Graph",
      "resourceAccess": [
        {
          "id": "Files.Read.All",
          "type": "Scope"
        },
        {
          "id": "Sites.Read.All",
          "type": "Scope"
        },
        {
          "id": "User.Read",
          "type": "Scope"
        }
      ]
    }
  ],
  "identifierUris": [
    "api://${{TAB_DOMAIN}}/${{AAD_APP_CLIENT_ID}}"
  ],
  "replyUrlsWithType": [
    {
      "url": "${{TAB_ENDPOINT}}/auth-end.html",
      "type": "Spa"
    }
  ]
}
