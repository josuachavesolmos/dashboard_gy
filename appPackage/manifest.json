{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "Axess Group",
    "websiteUrl": "https://www.axessgroup.com",
    "privacyUrl": "https://www.axessgroup.com/privacy",
    "termsOfUseUrl": "https://www.axessgroup.com/terms"
  },
  "name": {
    "short": "Axess Dashboard",
    "full": "Axess Group Operations Dashboard"
  },
  "description": {
    "short": "Operations dashboard for Quote Log, Personnel Planner, and Master Project tracking.",
    "full": "Interactive dashboard that visualizes data from Excel files stored in SharePoint. Track sales pipeline, personnel assignments, and project financials in real-time within Microsoft Teams."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#1a4548",
  "staticTabs": [
    {
      "entityId": "dashboard",
      "name": "Dashboard",
      "contentUrl": "${{TAB_ENDPOINT}}/index.html#/tab",
      "websiteUrl": "${{TAB_ENDPOINT}}/index.html#/tab",
      "scopes": ["personal"]
    }
  ],
  "configurableTabs": [
    {
      "configurationUrl": "${{TAB_ENDPOINT}}/index.html#/config",
      "canUpdateConfiguration": true,
      "scopes": ["team", "groupChat"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["${{TAB_DOMAIN}}"],
  "webApplicationInfo": {
    "id": "${{AAD_APP_CLIENT_ID}}",
    "resource": "api://${{TAB_DOMAIN}}/${{AAD_APP_CLIENT_ID}}"
  }
}
